#!/bin/bash
fun_badvpn() {
	echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
	echo -e "\033[0;34mв”ѓ\E[44;1;37m            GERENCIAR BADVPN             \E[0m\033[0;34mв”ѓ"
	echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"

	# Verificar si badvpn estГЎ corriendo
	if ps x | grep -w udpvpn | grep -v grep 1>/dev/null 2>/dev/null; then
		# Ubuntu 22+ usa ss; fallback a netstat si no existe
		if command -v ss &>/dev/null; then
			_bad_ports=$(ss -tlpn 2>/dev/null | grep 'badvpn' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
		else
			_bad_ports=$(netstat -nplt 2>/dev/null | grep 'badvpn-ud' | awk '{print $4}' | cut -d: -f2 | xargs)
		fi
		# Si ss no captura por nombre, buscar por puerto 7x00
		[[ -z "$_bad_ports" ]] && _bad_ports=$(ss -tlpn 2>/dev/null | grep -E ':7[0-9]{3}' | grep '127.0.0.1' | awk '{print $4}' | rev | cut -d: -f1 | rev | xargs)
		echo -e "\033[1;33mPORTAS ATIVAS\033[1;37m: \033[1;32m$_bad_ports"
	else
		sleep 0.1
	fi

	var_sks1=$(ps x | grep "udpvpn" | grep -v grep > /dev/null && echo -e "\033[1;32mв™¦ " || echo -e "\033[1;31mв—‹ ")
	echo ""
	echo -e "\E[38;5;196m|\E[38;5;33m01\E[38;5;196m|\033[1;37mвћњ \033[1;33mATIVAR BADVPN (PADRГѓO 7300) $var_sks1 \033[0m"
	echo -e "\E[38;5;196m|\E[38;5;33m02\E[38;5;196m|\033[1;37mвћњ \033[1;33mATIVAR TODAS AS PORTAS BADVPN (7100-7900)\033[0m"
	echo -e "\E[38;5;196m|\E[38;5;33m03\E[38;5;196m|\033[1;37mвћњ \033[1;33mABRIR PORTA ADICIONAL\033[0m"
	echo -e "\E[38;5;196m|\E[38;5;33m00\E[38;5;196m|\033[1;37mвћњ \033[1;33mVOLTAR\033[0m"
	echo ""
	echo -ne "\033[1;32mO QUE DESEJA FAZER \033[1;33m?\033[1;37m "
	read resposta

	# ---- [1] ATIVAR / DESATIVAR BADVPN PADRГѓO ----
	if [[ "$resposta" = '1' ]]; then
		if ps x | grep -w udpvpn | grep -v grep 1>/dev/null 2>/dev/null; then
			tput reset
			fun_stopbad() {
				for pidudpvpn in $(screen -ls | grep "\.udpvpn" | awk '{print $1}'); do
					screen -r -S "$pidudpvpn" -X quit 2>/dev/null
				done
				[[ $(grep -wc "udpvpn" /etc/autostart 2>/dev/null) != '0' ]] && sed -i '/udpvpn/d' /etc/autostart
				sleep 1
				screen -wipe >/dev/null 2>&1
			}
			echo -e "\033[1;32mDESATIVANDO O BADVPN\033[1;33m"
			fun_stopbad
			echo ""
			echo -e "\033[1;32mBADVPN DESATIVADO COM SUCESSO!\033[0m"
			sleep 0.5
			tput reset
			fun_badvpn
		else
			tput reset
			# Instalar badvpn si no existe el binario
			inst_udp() {
				mkdir -p /bin
				local _repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." 2>/dev/null && pwd)"

				# 1) Usar el binario incluido en este repositorio si existe
				if [[ -n "$_repo_root" && -s "$_repo_root/Install/badvpn-udpgw" ]]; then
					cp -f "$_repo_root/Install/badvpn-udpgw" /bin/badvpn-udpgw 2>/dev/null || true
				fi

				# 2) Fallback a la descarga directa desde GitHub
				if [[ ! -s /bin/badvpn-udpgw ]]; then
					wget -q --timeout=30 "https://github.com/VENHABRABO/SSHPLUS-NEW/raw/main/Install/badvpn-udpgw" -O /bin/badvpn-udpgw 2>/dev/null || true
				fi

				# 3) Гљltimo recurso: compilar desde fuente y copiar el binario real generado
				if [[ ! -s /bin/badvpn-udpgw ]]; then
					apt-get update -y >/dev/null 2>&1 || true
					apt-get install -y cmake make gcc libnss3-dev libssl-dev >/dev/null 2>&1 || true
					wget -q --timeout=60 "https://github.com/ambrop72/badvpn/archive/master.tar.gz" -O /tmp/badvpn.tar.gz 2>/dev/null || true
					if [[ -s /tmp/badvpn.tar.gz ]]; then
						mkdir -p /tmp/badvpn-build
						tar -xzf /tmp/badvpn.tar.gz -C /tmp/badvpn-build --strip-components=1
						cmake -S /tmp/badvpn-build -B /tmp/badvpn-build/build -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 >/dev/null 2>&1 || true
						cmake --build /tmp/badvpn-build/build --target udpgw -j"$(nproc 2>/dev/null || echo 1)" >/dev/null 2>&1 || true
						for _bin in /tmp/badvpn-build/build/udpgw/badvpn-udpgw /tmp/badvpn-build/udpgw/badvpn-udpgw /tmp/badvpn-build/badvpn-master/udpgw/badvpn-udpgw; do
							[[ -x "$_bin" ]] && cp -f "$_bin" /bin/badvpn-udpgw 2>/dev/null && break
						done
						rm -rf /tmp/badvpn-build /tmp/badvpn.tar.gz 2>/dev/null || true
					fi
				fi

				chmod 755 /bin/badvpn-udpgw 2>/dev/null || true
			}

			fun_udpon() {
				screen -dmS udpvpn /bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 10000 --max-connections-for-client 8 --client-socket-sndbuf 10000
				[[ $(grep -wc "udpvpn" /etc/autostart 2>/dev/null) = '0' ]] && {
					echo "ps x | grep 'udpvpn' | grep -v 'grep' || screen -dmS udpvpn /bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 10000 --max-connections-for-client 8 --client-socket-sndbuf 10000" >>/etc/autostart
				} || {
					sed -i '/udpvpn/d' /etc/autostart
					echo "ps x | grep 'udpvpn' | grep -v 'grep' || screen -dmS udpvpn /bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 10000 --max-connections-for-client 8 --client-socket-sndbuf 10000" >>/etc/autostart
				}
				sleep 1
			}

			echo -e "\033[1;32mVERIFICANDO BADVPN... \033[1;33m"
			# Instalar solo si no existe o estГЎ vacГ­o
			if [[ ! -x /bin/badvpn-udpgw ]]; then
				echo -e "\033[1;33mINSTALANDO BADVPN...\033[0m"
				inst_udp
			fi

			if [[ ! -x /bin/badvpn-udpgw ]]; then
				echo -e "\033[1;31mERRO: NГЈo foi possГ­vel instalar o badvpn-udpgw!\033[0m"
				sleep 2
				fun_badvpn
				return
			fi

			echo -e "\033[1;32mINICIANDO O BADVPN NA PORTA 7300...\033[0m"
			fun_udpon
			sleep 0.5

			# Verificar si arrancГі correctamente
			if ps x | grep -w udpvpn | grep -v grep 1>/dev/null 2>/dev/null; then
				echo -e "\033[1;32mBADVPN ATIVADO COM SUCESSO NA PORTA 7300!\033[0m"
			else
				echo -e "\033[1;31mERRO ao iniciar o BADVPN. Verifique o binГЎrio em /bin/badvpn-udpgw\033[0m"
			fi
			sleep 1
			tput reset
			sleep 0.3
			fun_badvpn
		fi

	# ---- [2] ATIVAR TODAS AS PORTAS (7100-7900) ----
	elif [[ "$resposta" = '2' ]]; then
		tput reset
		echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
		echo -e "\033[0;34mв”ѓ\E[44;1;37m            GERENCIAR BADVPN             \E[0m\033[0;34mв”ѓ"
		echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"

		if [[ ! -x /bin/badvpn-udpgw ]]; then
			echo -e "\033[1;31mBADVPN NГѓO INSTALADO! Ative primeiro com a opГ§ГЈo 01.\033[0m"
			sleep 2
			fun_badvpn
			return
		fi

		echo -e "\n\033[1;32mINICIANDO TODAS AS PORTAS BADVPN (7100-7900)...\033[0m"
		echo -e "\033[1;33mAVISO: As sessГµes fecham ao reiniciar a mГЎquina.\033[0m\n"
		sleep 1

		# Lanzar cada puerto en sesiГіn screen con nombre Гєnico
		for _p in 7100 7200 7300 7400 7500 7600 7700 7800 7900; do
			# Matar instancia previa en ese puerto si existe
			for _sid in $(screen -ls 2>/dev/null | grep "udpvpn${_p}" | awk '{print $1}'); do
				screen -r -S "$_sid" -X quit 2>/dev/null
			done
			screen -dmS udpvpn${_p} /bin/badvpn-udpgw \
				--listen-addr 127.0.0.1:${_p} \
				--max-clients 9000 \
				--max-connections-for-client 8 \
				--client-socket-sndbuf 10000 \
				--udp-mtu 9000
			echo -e "\033[1;32mPorta \033[1;37m${_p}\033[1;32m ativada!\033[0m"
			sleep 0.1
		done

		echo ""
		echo -e "\033[1;32mTODAS AS PORTAS BADVPN ATIVADAS COM SUCESSO!\033[0m\n"
		sleep 1
		tput reset
		sleep 0.3
		fun_badvpn

	# ---- [3] ABRIR PORTA ADICIONAL ----
	elif [[ "$resposta" = '3' ]]; then
		if ps x | grep -w udpvpn | grep -v grep 1>/dev/null 2>/dev/null; then
			tput reset
			echo -e "\033[0;34mв”Џв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”“\033[0m"
			echo -e "\033[0;34mв”ѓ\E[44;1;37m            GERENCIAR BADVPN             \E[0m\033[0;34mв”ѓ"
			echo -e "\033[0;34mв”—в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”›\033[0m"
			echo ""
			echo -ne "\033[1;32mQUAL PORTA DESEJA USAR \033[1;33m?\033[1;37m: "
			read porta
			[[ -z "$porta" ]] && {
				echo ""
				echo -e "\033[1;31mPorta invГЎlida!"
				sleep 0.5
				tput reset
				fun_badvpn
				return
			}
			fun_abrirptbad() {
				screen -dmS udpvpn${porta} /bin/badvpn-udpgw \
					--listen-addr 127.0.0.1:${porta} \
					--max-clients 10000 \
					--max-connections-for-client 8 \
					--client-socket-sndbuf 10000
				sleep 1
			}
			echo ""
			echo -e "\033[1;32mINICIANDO O BADVPN NA PORTA \033[1;31m$porta\033[0m"
			fun_abrirptbad
			sleep 0.5

			if ss -tlpn 2>/dev/null | grep -q ":${porta}" || netstat -tlpn 2>/dev/null | grep -q ":${porta}"; then
				echo -e "\033[1;32mPORTA \033[1;31m$porta \033[1;32mATIVADA COM SUCESSO!\033[0m"
			else
				echo -e "\033[1;33mPorta iniciada. Verifique com: ss -tlpn | grep $porta\033[0m"
			fi
			sleep 1
			tput reset
			sleep 0.3
			fun_badvpn
		else
			echo -e "\033[1;31mFUNГ‡ГѓO INDISPONГЌVEL\n\n\033[1;33mATIVE O BADVPN PRIMEIRO! (OpГ§ГЈo 01)\033[0m"
			sleep 1
			fun_badvpn
		fi

	# ---- [0] VOLTAR ----
	elif [[ "$resposta" = '0' ]]; then
		echo ""
		echo -e "\033[1;31mVoltando...\033[0m"
		sleep 1
		menu
	else
		echo ""
		echo -e "\033[1;31mOpГ§ГЈo invГЎlida!\033[0m"
		sleep 1
		fun_badvpn
	fi
}
tput reset
fun_badvpn
