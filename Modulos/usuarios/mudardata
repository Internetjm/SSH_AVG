#!/bin/bash

if [[ "$(id -u)" -ne 0 ]]; then
    if command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
        exec sudo bash "$0" "$@"
    fi
    echo -e "\033[1;31mDebe ejecutar este script como root o con sudo.\033[0m" >&2
    exit 1
fi

echo -e "\033[0;34mв•­в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•®\033[0m"
echo -e "\033[0;34mв”ѓ\E[44;1;37m         MUDAR DATA DE EXPIRACAO         \E[0m\033[0;34mв”ѓ"
echo -e "\033[0;34mв•°в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•Ї\033[0m\n"
echo -e "\033[1;33m LISTA DE USUARIOS E DATA DE EXPIRACAO:\033[0m\n"
tput setaf 7 ; tput bold 
database="/root/usuarios.db"
[[ -s "$database" ]] || database="$HOME/usuarios.db"
[[ -s "$database" ]] || database="/etc/SSHPlus/usuarios.db"

list_user=$(awk -F: '$3>=1000 && $3<65000 {print $1}' /etc/passwd 2>/dev/null | grep -vE '^(nobody|root|daemon|bin|sys|sync|games|man|lp|mail|news|uucp|proxy|www-data|backup|list|irc|gnats|systemd-.*)$' || true)
if [[ -s "$database" ]]; then
    list_user=$(awk 'NR==FNR {seen[$1]=1; next} ($1 in seen) {print $1}' "$database" <(printf '%s\n' "$list_user") 2>/dev/null || true)
fi
if [[ -z "$list_user" ]]; then
    list_user=$(awk -F: '$3>=1000 && $3<65000 {print $1}' /etc/passwd 2>/dev/null | grep -vE '^(nobody|root|daemon|bin|sys|sync|games|man|lp|mail|news|uucp|proxy|www-data|backup|list|irc|gnats|systemd-.*)$' || true)
fi
i=0
i=0
unset _userPass
while read user; do
	i=$(expr $i + 1)
	_oP=$i
	[[ $i == [1-9] ]] && i=0$i && oP+=" 0$i"
	expire=$(chage -l "$user" 2>/dev/null | awk -F: '/Account expires/ {print $2}' | xargs)
	[[ -z "$expire" ]] && expire=$(chage -l "$user" 2>/dev/null | grep -i 'Account expires' | awk '{print $NF}' | xargs)
	if [[ "$expire" == "never" || -z "$expire" ]]
	then
		echo -e "\033[1;31m[\033[1;36m$i\033[1;31m] \033[1;37m- \033[1;32m$user     \033[1;33m00/00/0000   S/DATA\033[0m"
	else
		databr=$(date -d "$expire" +"%Y%m%d" 2>/dev/null || true)
		hoje=$(date -d today +"%Y%m%d" 2>/dev/null)
		if [ $hoje -ge $databr ]
		then
			_user=$(echo -e "\033[1;31m[\033[1;36m$i\033[1;31m] \033[1;37m- \033[1;32m$user\033[1;37m")
			datanormal=$(printf '\033[1;31m%s\033[0m' "$(date -d "$expire" '+%d/%m/%Y' 2>/dev/null || echo '00/00/0000')")
			expired=$(echo -e "\033[1;31mVENCEU\033[0m")
			printf '%-62s%-20s%s\n' "$_user" "$datanormal" "$expired"
			echo "exp" > /tmp/exp
		else
			_user=$(echo -e "\033[1;31m[\033[1;36m$i\033[1;31m] \033[1;37m- \033[1;32m$user\033[1;37m")
			datanormal=$(printf '\033[1;33m%s\033[0m' "$(date -d "$expire" '+%d/%m/%Y' 2>/dev/null || echo '00/00/0000')")
			ative=$(echo -e "\033[1;32mVALIDO\033[0m")
			printf '%-62s%-20s%s\n' "$_user" "$datanormal" "$ative"
		fi
	fi
	_userPass+="\n${_oP}:${user}"
done <<< "${list_user}"
tput sgr0
echo ""
if [ -a /tmp/exp ]
then
	rm /tmp/exp
fi
num_user=$(printf '%s\n' "$list_user" | awk 'NF{c++} END {print c+0}')
echo -ne "\033[1;32mDigite ou selecione um usuario \033[1;33m[\033[1;36m1\033[1;33m-\033[1;36m$num_user\033[1;33m]\033[1;37m: " ; read option
if [[ -z $option ]]
then
	echo ""
	tput setaf 7 ; tput setab 1 ; tput bold ; echo "Erro,  Nome de usuГЎrio vazio ou invГЎlido! " ; tput sgr0
	exit 1
fi
usuario=$(echo -e "${_userPass}" | grep -E "\b$option\b" | cut -d: -f2)
if [[ -z $usuario ]]
then
	echo ""
	tput setaf 7 ; tput setab 1 ; tput bold ; echo "Erro,  Nome de usuГЎrio vazio ou invГЎlido!!! " ; tput sgr0
	echo ""
	exit 1
else
	if [[ `grep -c /$usuario: /etc/passwd` -ne 0 ]]
	then
	    echo ""
	    echo -e "\033[1;31mEX:\033[1;33m(\033[1;32mDATA: \033[1;37mDIA/MГЉS/ANO \033[1;33mOU \033[1;32mDIAS: \033[1;37m30\033[1;33m)"
	    echo ""
	    echo -ne "\033[1;32mNova data ou dias para o usuario \033[1;33m$usuario: \033[1;37m"; read inputdate
	    if [[ "$(echo -e "$inputdate" | grep -c "/")" = "0" ]]; then 
	    	udata=$(date "+%d/%m/%Y" -d "+$inputdate days")
	    	sysdate="$(echo "$udata" | awk -v FS=/ -v OFS=- '{print $3,$2,$1}')"
	    else
	    	udata=$(echo -e "$inputdate")
	    	sysdate="$(echo "$inputdate" | awk -v FS=/ -v OFS=- '{print $3,$2,$1}')"
	    fi
		if (date "+%Y-%m-%d" -d "$sysdate" > /dev/null  2>&1)
		then
			if [[ -z $inputdate ]]
			then
				echo ""
				tput setaf 7 ; tput setab 1 ; tput bold ;	echo "VocГЄ digitou uma data invГЎlida ou inexistente!" ; echo "Digite uma data vГЎlida no formato DIA/MГЉS/ANO " ; echo "Por exemplo: 21/04/2018" ; tput sgr0 ; tput sgr0
				echo ""
				exit 1	
			else
				if (echo $inputdate | egrep [^a-zA-Z] &> /dev/null)
				then
					today="$(date -d today +"%Y%m%d")"
					timemachine="$(date -d "$sysdate" +"%Y%m%d")"
					if [ $today -ge $timemachine ]
					then
						echo ""
						tput setaf 7 ; tput setab 1 ; tput bold ;	echo "VocГЄ digitou uma data passada ou o dia atual!" ; echo "Digite uma data futura e vГЎlida no formato DIA/MГЉS/ANO" ; echo "Por exemplo: 21/04/2018" ; tput sgr0
						echo ""
						exit 1
					else
						chage -E "$sysdate" "$usuario" 2>/dev/null || usermod -e "$sysdate" "$usuario" 2>/dev/null || true
						echo ""
						tput setaf 7 ; tput setab 4 ; tput bold ; echo "Sucesso UsuГЎrio $usuario nova data: $udata " ; tput sgr0
						echo ""
						exit 1
					fi
				else
					echo ""
					tput setaf 7 ; tput setab 1 ; tput bold ;	echo "VocГЄ digitou uma data invГЎlida ou inexistente!" ; echo "Digite uma data vГЎlida no formato DIA/MГЉS/ANO" ; echo "Por exemplo: 21/04/2018" ; tput sgr0
					echo ""
					exit 1
				fi
			fi
		else
			echo ""
			tput setaf 7 ; tput setab 1 ; tput bold ;	echo "VocГЄ digitou uma data invГЎlida ou inexistente!" ; echo "Digite uma data vГЎlida no formato DIA/MГЉS/ANO" ; echo "Por exemplo: 21/04/2018" ; tput sgr0
			echo ""
			exit 1
		fi
	else
		echo " "
		tput setaf 7 ; tput setab 1 ; tput bold ;	echo "O usuГЎrio $usuario nГЈo existe!" ; tput sgr0
		echo " "
		exit 1
	fi
fi