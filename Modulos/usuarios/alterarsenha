#!/bin/bash

if [[ "$(id -u)" -ne 0 ]]; then
    if command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
        exec sudo bash "$0" "$@"
    fi
    echo -e "\033[1;31mDebe ejecutar este script como root o con sudo.\033[0m" >&2
    exit 1
fi

mkdir -p /etc/SSHPlus/senha 2>/dev/null
chmod 755 /etc/SSHPlus /etc/SSHPlus/senha 2>/dev/null || true

tput setaf 7 ; tput setab 4 ; tput bold ; printf '%35s%s%-10s\n' "Alterar Senha de UsuГЎrio" ; tput sgr0
echo ""
echo -e "\033[0;34mв•­в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•®\033[0m"
echo -e "\033[0;34mв”ѓ\E[44;1;37m    LISTA DE USUARIOS E SUAS SENHAS      \E[0m\033[0;34mв”ѓ"
echo -e "\033[0;34mв•°в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв•Ї\033[0m"
echo""
_userT=$(awk -F: '$3>=1000 && $3<65000 {print $1}' /etc/passwd 2>/dev/null | grep -vE '^(nobody|root|daemon|bin|sys|sync|games|man|lp|mail|news|uucp|proxy|www-data|backup|list|irc|gnats|systemd-.*)$')
i=0
unset _userPass
while read _user; do
	i=$(expr $i + 1)
	_oP=$i
	[[ $i == [1-9] ]] && i=0$i && oP+=" 0$i"
	if [[ -e "/etc/SSHPlus/senha/$_user" ]]; then
		_senha="$(cat /etc/SSHPlus/senha/$_user)"
	else
		_senha='Null'
	fi
	suser=$(echo -e "\033[1;31m[\033[1;36m$i\033[1;31m] \033[1;37m- \033[1;32m$_user\033[0m")
    ssenha=$(echo -e "\033[1;33mSenha\033[1;37m: $_senha")
    printf '%-60s%s\n' "$suser" "$ssenha"
	_userPass+="\n${_oP}:${_user}"
done <<< "${_userT}"
num_user=$(printf '%s\n' "$_userT" | awk 'NF{c++} END{print c+0}')
echo ""
echo -ne "\033[1;32mDigite ou selecione um usuario \033[1;33m[\033[1;36m1\033[1;31m-\033[1;36m$num_user\033[1;33m]\033[1;37m: " ; read option
user=$(echo -e "${_userPass}" | grep -E "\b$option\b" | cut -d: -f2)
if [[ -z $option ]]
then
	tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "Campo vazio ou invГЎlido!" ; echo "" ; tput sgr0
	exit 1
elif [[ -z $user ]]
then
	tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "VocГЄ digitou um nome vazio ou invГЎlido!" ; echo "" ; tput sgr0
	exit 1
else
	if [[ `grep -c /$user: /etc/passwd` -ne 0 ]]
	then
		echo -ne "\n\033[1;32mNova senha para o usuario \033[1;33m$user\033[1;37m: "; read password
		sizepass=$(echo ${#password})
		if [[ $sizepass -lt 4 ]]
		then
			tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "Senha vazio ou invГЎlida! use no minimo 4 caracteres" ; echo "" ; tput sgr0
			exit 1
		else
			ps x | grep $user | grep -v grep | grep -v pt > /tmp/rem
			if [[ `grep -c $user /tmp/rem` -eq 0 ]]
			then
				echo "$user:$password" | chpasswd 2>/dev/null || true
				tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "A senha do usuГЎrio $user foi alterada para: $password" ; echo "" ; tput sgr0
				mkdir -p /etc/SSHPlus/senha 2>/dev/null
				echo "$password" > "/etc/SSHPlus/senha/$user" 2>/dev/null || true
				exit 1
			else
				echo ""
				tput setaf 7 ; tput setab 4 ; tput bold ; echo "UsuГЎrio conectado. Desconectando..." ; tput sgr0
				pkill -f "$user" 2>/dev/null || true
				echo "$user:$password" | chpasswd 2>/dev/null || true
				tput setaf 7 ; tput setab 1 ; tput bold ; echo "" ; echo "A senha do usuГЎrio $user foi alterada para: $password" ; echo "" ; tput sgr0
				mkdir -p /etc/SSHPlus/senha 2>/dev/null
				echo "$password" > "/etc/SSHPlus/senha/$user" 2>/dev/null || true
				exit 1
			fi
		fi
	else
		tput setaf 7 ; tput setab 4 ; tput bold ; echo "" ; echo "O usuГЎrio $user nГЈo existe!" ; echo "" ; tput sgr0
	fi
fi