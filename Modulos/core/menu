#!/bin/bash

# ============================================================
#   AVG TEAM - Manager Script
#   Diseño profesional, colores consistentes, bugs corregidos
# ============================================================

tput reset

# ──────────────────────────────────────────────
# BARRA DE PROGRESO
# ──────────────────────────────────────────────
fun_bar() {
  comando[0]="$1"
  comando[1]="$2"
  (
    [[ -e $HOME/fim ]] && rm -f "$HOME/fim"
    [[ ! -e /usr/lib/sshplus ]] && rm -f /bin/menu 2>/dev/null
    ${comando[0]} -y >/dev/null 2>&1
    ${comando[1]} -y >/dev/null 2>&1
    touch "$HOME/fim"
  ) >/dev/null 2>&1 &

  tput civis
  echo -ne "\033[1;34m ["
  while true; do
    for ((i = 0; i < 20; i++)); do
      echo -ne "\033[1;36m▓"
      sleep 0.08s
    done
    [[ -e $HOME/fim ]] && rm -f "$HOME/fim" && break
    echo -e "\033[1;34m]"
    sleep 1s
    tput cuu1; tput dl1
    echo -ne "\033[1;34m ["
  done
  echo -e "\033[1;34m]\033[0m \033[1;32m✔ Completado\033[0m"
  tput cnorm
}

# ──────────────────────────────────────────────
# COLORES Y ESTILOS (variables reutilizables)
# ──────────────────────────────────────────────
R="\033[0m"
BORDE="\E[38;5;33m"
TITULO="\E[38;5;15m"
NUM="\E[38;5;214m"
FLECHA="\033[1;37m"
ITEM="\E[38;5;195m"
OK="\033[1;32m"
ERR="\033[1;31m"
INFO="\033[1;33m"
SEP="\E[38;5;240m"

# ──────────────────────────────────────────────
# CABECERA REUTILIZABLE
# ──────────────────────────────────────────────
cabecera() {
  local titulo="${1:-AVG TEAM}"
  local ancho=62
  local pad=$(( (ancho - ${#titulo}) / 2 ))
  local spaces
  printf -v spaces '%*s' "$pad" ''
  echo -e "${BORDE}┌──────────────────────────────────────────────────────────────┐${R}"
  echo -e "${BORDE}│${TITULO}${spaces}${titulo}${spaces}${R}${BORDE}│${R}"
  echo -e "${BORDE}└──────────────────────────────────────────────────────────────┘${R}"
}

linea() {
  echo -e "${SEP}──────────────────────────────────────────────────────────────${R}"
}

opcion() {
  # opcion <num> <texto>
  echo -e " ${BORDE}[${NUM}$(printf '%02d' $1)${BORDE}]${FLECHA}➜ ${ITEM}${2}${R}"
}

IP=$(cat /etc/IP 2>/dev/null || hostname -I | awk '{print $1}')
x="ok"

# ══════════════════════════════════════════════
# SINCRONIZAR PANEL WEB
# ══════════════════════════════════════════════
syncpw() {
  clear
  echo "America/Bogota" > /etc/timezone
  ln -fs /usr/share/zoneinfo/America/Bogota /etc/localtime
  dpkg-reconfigure --frontend noninteractive tzdata >/dev/null 2>&1
  rm -f ./*.sh 2>/dev/null
  apt-get install -y unzip >/dev/null 2>&1
  [[ $(uname -m) == "aarch64" ]] && arc='arm64' || arc='64'
  wget -q "sshplus.xyz/scripts/${arc}/sync.tar.bz2"
  rm -f /opt/sshplus/plugin-sync 2>/dev/null
  tar -xjf sync.tar.bz2 -C /opt/sshplus/ >/dev/null 2>&1
  chmod 777 /opt/sshplus/*-sync 2>/dev/null
  wget -q "sshplus.xyz/scripts/utilitarios/syncpainel/modulos.zip"
  unzip -o modulos.zip >/dev/null 2>&1
  chmod +x ./*.sh 2>/dev/null
  service ssh restart >/dev/null 2>&1
  echo -e "\n${OK}✔ Sincronización completada.${R}"
  sleep 2
  cat /dev/null > ~/.bash_history && history -c && clear
  echo -e "${INFO}Entra al panel y crea una cuenta SSH para verificar que todo esté OK.${R}"
  rm -f inst sync.tar.bz2 modulos.zip 2>/dev/null
}

# ══════════════════════════════════════════════
# HERRAMIENTAS ÚTILES
# ══════════════════════════════════════════════
uteis() {
  while true; do
    clear
    cabecera "⚙  HERRAMIENTAS"
    echo ""
    opcion 1 "SINCRONIZAR PANEL WEB"
    opcion 2 "MEMORIA VIRTUAL (SWAP)"
    opcion 0 "MENÚ PRINCIPAL"
    echo ""
    echo -ne " ${OK}Opción ${FLECHA}»${R} "; read x
    case "$x" in
      1|01) clear; syncpw ;;
      2|02) clear; swapmemory ;;
      0|00) menu; return ;;
      *)    echo -e "\n${ERR}✘ Opción inválida.${R}"; sleep 1.5 ;;
    esac
  done
}

