      9|09)  conexao;                  exit ;;
      10)    clear; echo -e " ${INFO}Presiona CTRL+C para salir.${R}"; sleep 4; nload ;;
      11)    clear; otimizar;          echo -ne "\n ${ERR}[ENTER]${R} para volver al menú "; read ;;
      12)    clear; badvpn;            exit ;;
      13)    autoexec ;;
      14)    clear; reiniciarsistema ;;
      15)    clear; reiniciarservicos; sleep 3 ;;
      16)    clear; senharoot;         sleep 3 ;;
      17)    clear; detalhes;          echo -ne "\n ${ERR}[ENTER]${R} para volver al menú "; read ;;
      18)    clear; fun_hysteria_menu ;;
      19)    clear; fun_zivpn_menu ;;
      20)    clear; uteis;             sleep 0.5 ;;
      21)    clear; fun_slowdns_menu ;;
      22)    clear; fun_xray_menu ;; # <-- Llama al nuevo submenú de gestión
      0|00)
        echo -e "\n ${ERR}Saliendo de AVG TEAM...${R}"
        sleep 1.5; clear; exit ;;
      *)
        echo -e "\n ${ERR}✘ Opción inválida.${R}"; sleep 1.5 ;;
    esac
    clear
  done
