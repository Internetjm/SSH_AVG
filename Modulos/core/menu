  fi
  opcion 1 "INSTALAR HYSTERIA UDP"
  opcion 0 "VOLVER"
  echo ""
  echo -ne " ${OK}Opción ${FLECHA}»${R} "; read opc
  [[ "$opc" != '1' && "$opc" != '01' ]] && { menu; return; }

  echo -e "\n ${INFO}Instalando Hysteria UDP Manager...${R}"
  BASE_URL="https://raw.githubusercontent.com/Internetjm/SSH_AVG/main/Modulos/udphysteria"
