#!/bin/bash
DB_FILE="/root/usuarios.db"
[[ -s "$DB_FILE" ]] || DB_FILE="$HOME/usuarios.db"
[[ -s "$DB_FILE" ]] || DB_FILE="/etc/SSHPlus/usuarios.db"
[[ -s "$DB_FILE" ]] || touch "$DB_FILE" 2>/dev/null

echo -e "\033[0;34m╭━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╮\033[0m"
echo -e "\033[0;34m┃\E[44;1;37m USUARIO         SENHA       LIMITE      VALIDADE \E[0m\033[0;34m┃"
echo -e "\033[0;34m╰━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╯\033[0m\n"
[[ ! -e /bin/versao ]] && rm -rf /bin/menu

mapfile -t _usuarios < <(
  if [[ -s "$DB_FILE" ]]; then
    awk '{print $1}' "$DB_FILE" | awk 'NF'
  else
    awk -F: '$3 >= 1000 && $7 == "/bin/false" {print $1}' /etc/passwd | sort -u
  fi
)

for users in "${_usuarios[@]}"; do
  [[ -z "$users" ]] && continue
  if grep -qw "$users" "$DB_FILE" 2>/dev/null; then
      lim=$(awk -v user="$users" '$1 == user {print $2; exit}' "$DB_FILE")
  else
      lim="1"
  fi
  if [[ -e "/etc/SSHPlus/senha/$users" ]]; then
      senha=$(cat "/etc/SSHPlus/senha/$users")
  else
      senha="Null"
  fi
  datauser=$(chage -l "$users" 2>/dev/null | awk -F: '/Account expires/{print $2}' | sed 's/^ *//;s/ *$//')
  if [[ -z "$datauser" || "$datauser" == "never" || "$datauser" == "Nunca" ]]; then
      data="\033[1;33mNunca\033[0m"
  else
      expire_epoch=$(date -d "$datauser" +%s 2>/dev/null)
      today_epoch=$(date +%s)
      if [[ -n "$expire_epoch" && "$today_epoch" -ge "$expire_epoch" ]]; then
          data="\033[1;31mVenceu\033[0m"
      else
          days=$(((expire_epoch - today_epoch) / 86400))
          data="$(printf '%s \033[1;37mDias\033[0m' "$days")"
      fi
  fi
  Usuario=$(printf ' %-15s' "$users")
  Senha=$(printf '%-13s' "$senha")
  Limite=$(printf '%-10s' "$lim")
  Data=$(printf '%-1s' "$data")
  echo -e "\033[1;33m$Usuario \033[1;37m$Senha \033[1;37m$Limite \033[1;32m$Data\033[0m"
done
echo ""
_tuser=$(awk -F: '$3>=1000 {print $1}' /etc/passwd | grep -v nobody | wc -l)
_ons=$(ps -x | grep sshd | grep -v root | grep priv | wc -l)
[[ "$(cat /etc/SSHPlus/Exp)" != "" ]] && _expuser=$(cat /etc/SSHPlus/Exp) || _expuser="0"
[[ -e /etc/openvpn/openvpn-status.log ]] && _onop=$(grep -c "10.8.0" /etc/openvpn/openvpn-status.log) || _onop="0"
[[ -e /etc/default/dropbear ]] && _drp=$(ps aux | grep dropbear | grep -v grep | wc -l) _ondrp=$(($_drp - 1)) || _ondrp="0"
_onli=$(($_ons + $_onop + $_ondrp))
echo -e "\033[1;33m• \033[1;36mTOTAL USUARIOS\033[1;37m $_tuser \033[1;33m• \033[1;32mONLINES\033[1;37m: $_onli \033[1;33m• \033[1;31mVENCIDOS\033[1;37m: $_expuser \033[1;33m•\033[0m"
