        "screen -dmS udpvpn /bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 10000 --max-connections-for-client 8 --client-socket-sndbuf 10000"
    )

    for _cmd in "${_cmds[@]}"; do
        grep -qxF "$_cmd" /etc/autostart 2>/dev/null || echo "$_cmd" >> /etc/autostart
